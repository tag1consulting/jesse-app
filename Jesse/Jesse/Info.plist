<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSCameraUsageDescription</key>
	<string>Scan the pairing QR shown by the Jesse bridge, and take photos to attach to a conversation.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Transcribe the audio you speak on your Apple Watch so Jesse can answer it.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>Jesse attaches your recent workouts so you can ask it to log them.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSExceptionDomains</key>
		<dict>
			<key>ts.net</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
		</dict>
	</dict>
</dict>
</plist>
